{
  "name": "20_clinic_patient_forecast_benchmark",
  "description": "Apples-to-apples benchmark for graph-dynamic patient-forecast scenarios. The geo scenario uses the 20 POC locations from the B&B Paper 2026 Appendix A. The GCN-DDPG arm uses the current residual MYO-anchor plus local-search distillation policy.",
  "algorithms": [
    "gcn_ddpg",
    "flat_ddpg",
    "td3",
    "sac",
    "ppo",
    "myo",
    "iso",
    "mdl1",
    "mdl2"
  ],
  "primary_algorithms": [
    "gcn_ddpg",
    "flat_ddpg",
    "td3",
    "myo",
    "iso",
    "mdl1",
    "mdl2"
  ],
  "second_phase_algorithms": [
    "sac",
    "ppo"
  ],
  "learned_config_paths": {
    "gcn_ddpg": "configs/gcn_ddpg_20_clinic.yaml",
    "flat_ddpg": "configs/flat_ddpg_20_clinic.yaml",
    "td3": "configs/td3_20_clinic.yaml",
    "sac": "configs/sac_20_clinic.yaml",
    "ppo": "configs/ppo_20_clinic.yaml"
  },
  "algorithm_settings": {
    "gcn_ddpg": {
      "config_overrides": {
        "residual_action": {
          "enabled": true,
          "base_policy": "myo",
          "scale": 0.05,
          "group_scales": {
            "specimen_transfer": 0.0,
            "reagent_transfer": 0.0,
            "capacity_transfer": 0.0,
            "replenishment": 0.05
          },
          "l2_weight": 0.02
        },
        "imitation_pretrain": {
          "enabled": true,
          "policy": "myo",
          "episodes": 20,
          "epochs": 8,
          "batch_size": 256,
          "seed": 90000,
          "populate_replay_buffer": true,
          "regularization_weight": 1.0,
          "regularization_batch_size": 64
        },
        "elite_imitation": {
          "enabled": true,
          "warmup_episodes": 5,
          "min_improvement": 0.0,
          "max_episodes": 5,
          "epochs": 6,
          "batch_size": 64
        }
      },
      "local_search": {
        "enabled": true,
        "baseline_policy": "myo",
        "seed": 90000,
        "rollouts": 20,
        "lookahead": 6,
        "epsilons": [0.02, 0.05, 0.08],
        "epochs": 16,
        "min_improvement": 0.0
      }
    }
  },
  "scenarios": [
    {
      "name": "graph_dynamic_patient_forecast",
      "env_config": "experiments/configs/20_clinic_graph_dynamic_patient_forecast.json"
    },
    {
      "name": "graph_dynamic_patient_forecast_geo",
      "env_config": "experiments/configs/20_clinic_graph_dynamic_patient_forecast_geo.json"
    }
  ],
  "budgets": {
    "smoke": {
      "seeds": [0],
      "num_episodes": 1,
      "max_steps_per_episode": 3,
      "batch_size": 2,
      "checkpoint_interval": 1,
      "progress_interval": 1,
      "evaluation_replications": 1,
      "evaluation_seed": 10000,
      "local_search": {
        "gcn_ddpg": {
          "rollouts": 1,
          "lookahead": 1,
          "epsilons": [0.05],
          "epochs": 1,
          "min_improvement": -1.0
        }
      }
    },
    "pilot": {
      "seeds": [0, 1, 2],
      "num_episodes": 50,
      "max_steps_per_episode": 52,
      "batch_size": 64,
      "checkpoint_interval": 50,
      "progress_interval": 10,
      "evaluation_replications": 100,
      "evaluation_seed": 50000
    },
    "formal": {
      "seeds": [0, 1, 2],
      "num_episodes": 50,
      "max_steps_per_episode": 52,
      "batch_size": 64,
      "checkpoint_interval": 50,
      "progress_interval": 10,
      "evaluation_replications": 500,
      "evaluation_seed": 150000
    },
    "full": {
      "seeds": [0, 1, 2, 3, 4],
      "num_episodes": 1000,
      "max_steps_per_episode": 52,
      "batch_size": 64,
      "checkpoint_interval": 100,
      "progress_interval": 50,
      "evaluation_replications": 500,
      "evaluation_seed": 10000
    }
  },
  "output_root": "results/patient_forecast_benchmark",
  "figure_root": "figures/patient_forecast_benchmark",
  "plot_metrics": [
    "total_cost_mean",
    "service_level_mean",
    "average_waiting_time_mean",
    "transshipment_cost_mean"
  ]
}
